# ══════════════════════════════════════════════════════════════
# French Market Intel — Configuration environnement
# ══════════════════════════════════════════════════════════════
# Copiez ce fichier en .env et remplissez vos clés.

# ── APIs News ────────────────────────────────────────────────
# NewsAPI.org (gratuit : 100 req/jour) — https://newsapi.org
NEWSAPI_KEY=1341b98a8ab3403ca98df3156d29c9a6

# GNews.io (fallback, gratuit : 100 req/jour) — https://gnews.io
GNEWS_KEY=033eb96af0b7fb5f993685e095b8359a

# ── API Boursière (optionnel) ────────────────────────────────
# Polygon.io — uniquement si yfinance insuffisant
# Plan gratuit limité aux marchés US ; payant pour Euronext
POLYGON_KEY=

# ── Hugging Face (optionnel) ─────────────────────────────────
# Token pour l'Inference API (sentiment NLP avancé)
# https://huggingface.co/settings/tokens
HF_TOKEN=

# ── Email SMTP ───────────────────────────────────────────────
# Pour Gmail : activer "App Passwords" dans les paramètres Google
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email@gmail.com
SMTP_PASS=votre_app_password
EMAIL_TO=destinataire1@email.com,destinataire2@email.com

# ── Paramètres métier ────────────────────────────────────────
NEWS_MAX_ARTICLES=50
REPORT_TOP_N_NEWS=30
IMPACT_TOP_STOCKS=8

# ── Planification ────────────────────────────────────────────
# Heure locale (Europe/Paris) pour le rapport quotidien
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=30
